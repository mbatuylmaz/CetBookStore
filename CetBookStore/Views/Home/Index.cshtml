@model CetBookStore.ViewModels.HomePageViewModel
@{
    ViewData["Title"] = "Home";
}

<div class="page-heading">
    <h1 class="h3 mb-1">Welcome</h1>
    <p class="text-muted mb-0 small">Browse books by category or open a book to add it to your cart (you need to be logged in).</p>
</div>

<section class="mb-5">
    <h2 class="h5 mb-3">Most commented</h2>
    <div class="row g-4">
        @foreach (var book in Model.MostCommenteds)
        {
            <div class="col-sm-6 col-lg-4">
                <div class="card store-card h-100 shadow-sm">
                    <img src="https://images.unsplash.com/photo-1544947950-fa07a98d2378?w=600&q=80" class="card-img-top home-book-cover" alt="" />
                    <div class="card-body d-flex flex-column">
                        <h3 class="h6 card-title">@book.Title</h3>
                        <p class="card-text small text-muted mb-2">@book.Author</p>
                        <p class="h6 mb-3 mt-auto">@book.Price.ToString("N2") ₺</p>
                        <a class="btn btn-primary btn-sm" asp-controller="Books" asp-action="Details" asp-route-id="@book.Id">View book</a>
                    </div>
                </div>
            </div>
        }
    </div>
</section>

<section class="mb-5">
    <h2 class="h5 mb-3">New arrivals</h2>
    <div class="row g-4">
        @foreach (var book in Model.NewArrivals)
        {
            <div class="col-sm-6 col-lg-4">
                <div class="card store-card h-100 shadow-sm">
                    <img src="https://images.unsplash.com/photo-1512820790803-83ca734da794?w=600&q=80" class="card-img-top home-book-cover" alt="" />
                    <div class="card-body d-flex flex-column">
                        <h3 class="h6 card-title">@book.Title</h3>
                        <p class="card-text small text-muted mb-2">@book.Author</p>
                        <p class="h6 mb-3 mt-auto">@book.Price.ToString("N2") ₺</p>
                        <a class="btn btn-primary btn-sm" asp-controller="Books" asp-action="Details" asp-route-id="@book.Id">View book</a>
                    </div>
                </div>
            </div>
        }
    </div>
</section>

<section class="mb-2">
    <h2 class="h5 mb-3">More books</h2>
    <div class="row g-4">
        @foreach (var book in Model.RandomBoooks)
        {
            <div class="col-sm-6 col-lg-4">
                <div class="card store-card h-100 shadow-sm">
                    <img src="https://images.unsplash.com/photo-1495446815901-a7297e633e8d?w=600&q=80" class="card-img-top home-book-cover" alt="" />
                    <div class="card-body d-flex flex-column">
                        <h3 class="h6 card-title">@book.Title</h3>
                        <p class="card-text small text-muted mb-2">@book.Author</p>
                        <p class="h6 mb-3 mt-auto">@book.Price.ToString("N2") ₺</p>
                        <a class="btn btn-outline-primary btn-sm" asp-controller="Books" asp-action="Details" asp-route-id="@book.Id">View book</a>
                    </div>
                </div>
            </div>
        }
    </div>
</section>

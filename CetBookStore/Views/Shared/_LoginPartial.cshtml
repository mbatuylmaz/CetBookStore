@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

<ul class="navbar-nav ms-md-auto">
@if (SignInManager.IsSignedIn(User))
{
    <li class="nav-item">
        <a class="nav-link" asp-controller="Orders" asp-action="MyOrders">My orders</a>
    </li>
    <li class="nav-item">
        <span class="nav-link disabled d-none d-md-inline">@User.Identity?.Name</span>
    </li>
    <li class="nav-item">
        <form class="d-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
            <button type="submit" class="btn btn-sm btn-outline-secondary ms-md-1">Log out</button>
        </form>
    </li>
}
else
{
    <li class="nav-item">
        <a class="nav-link" asp-area="Identity" asp-page="/Account/Register">Register</a>
    </li>
    <li class="nav-item">
        <a class="btn btn-sm btn-primary ms-md-1 mt-1 mt-md-0" asp-area="Identity" asp-page="/Account/Login">Log in</a>
    </li>
}
</ul>

@model List<CetBookStore.Models.CartLine>
@{
    ViewData["Title"] = "Cart";
    decimal total = 0;
    foreach (var line in Model)
    {
        total += line.Price * line.Quantity;
    }
}

<div class="page-heading">
    <h1 class="h3 mb-1">Shopping cart</h1>
    <p class="text-muted small mb-0">Review items before you buy.</p>
</div>

@if (Model.Count == 0)
{
    <div class="alert alert-light border mt-3">
        Your cart is empty. <a asp-controller="Books" asp-action="Index">Go to books</a>
    </div>
}
else
{
    <div class="card store-card shadow-sm mt-3">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-hover mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Product</th>
                            <th class="text-center" style="width: 6rem;">Qty</th>
                            <th class="text-end" style="width: 7rem;">Price</th>
                            <th class="text-end" style="width: 8rem;">Subtotal</th>
                            <th style="width: 5rem;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var line in Model)
                        {
                            var lineTotal = line.Price * line.Quantity;
                            <tr>
                                <td>@line.ProductName</td>
                                <td class="text-center">@line.Quantity</td>
                                <td class="text-end">@line.Price.ToString("N2") ₺</td>
                                <td class="text-end fw-medium">@lineTotal.ToString("N2") ₺</td>
                                <td>
                                    @if (User.Identity?.IsAuthenticated == true)
                                    {
                                        <form asp-action="Remove" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="bookId" value="@line.BookId" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger">Remove</button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card-footer bg-white d-flex flex-wrap align-items-center justify-content-between gap-2">
            <span class="fs-5 mb-0">Total: <strong>@total.ToString("N2") ₺</strong></span>
            @if (User.Identity?.IsAuthenticated == true)
            {
                <form asp-action="Purchase" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-success">Buy</button>
                </form>
            }
            else
            {
                <span class="text-muted small">Log in to complete your purchase.</span>
            }
        </div>
    </div>
}

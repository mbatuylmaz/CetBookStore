@model CetBookStore.Models.Category

@{
    ViewData["Title"] = Model.Name;
}

<div class="page-heading">
    <h1 class="h3 mb-1">@Model.Name</h1>
    <p class="text-muted small mb-0">Books in this category.</p>
</div>

<div class="table-responsive card store-card shadow-sm mt-3">
    <table class="table table-hover mb-0 align-middle">
        <thead class="table-light">
            <tr>
                <th>Title</th>
                <th>Author</th>
                <th>Publisher</th>
                <th class="text-end">Price</th>
                <th style="width: 8rem;"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Books ?? Enumerable.Empty<Book>())
            {
                <tr>
                    <td>
                        <a asp-controller="Books" asp-action="Details" asp-route-id="@item.Id">@item.Title</a>
                    </td>
                    <td>@item.Author</td>
                    <td>@item.Publisher</td>
                    <td class="text-end">
                        @if (item.IsInSale)
                        {
                            <span class="text-muted text-decoration-line-through small me-1">@item.PreviousPrice.ToString("N2")</span>
                        }
                        @item.Price.ToString("N2") ₺
                    </td>
                    <td>
                        <a class="btn btn-sm btn-outline-primary" asp-controller="Books" asp-action="Details" asp-route-id="@item.Id">View</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
